{
  "name": "agentifyer",
  "version": "0.1.6",
  "description": "File-backed workspace for orchestrating coding agents - use as a shared backend for AI coding tools",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "agentifyer": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --loader tsx ./src/cli.ts",
    "start": "node ./dist/cli.js"
  },
  "keywords": [
    "agents",
    "cli",
    "developer-tools",
    "orchestration",
    "ai-coding",
    "claude",
    "aider"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CazyUndee/agentifyer.git"
  }
}
